FROM node:20-alpine

WORKDIR /app

ARG VITE_API_BASE_URL
ARG VITE_DOG_INITIAL_PAGE
ARG VITE_DOG_PAGE_SIZE

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_DOG_INITIAL_PAGE=${VITE_DOG_INITIAL_PAGE}
ENV VITE_DOG_PAGE_SIZE=${VITE_DOG_PAGE_SIZE}

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host"]
